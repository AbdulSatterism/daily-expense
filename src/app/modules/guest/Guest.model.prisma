enum CapitalApplicationStatus {
  SUBMITTED
  APPROVED
  REJECTED
}


model CapitalApplication {
  id String @id @default(uuid())

  name      String
  email          String
  phone String

  has_noa               Boolean @default(false)
  has_cbs_report        Boolean @default(false)
  has_acra_record      Boolean @default(false)
  has_bank_statement   Boolean @default(false)

  capital_range String?

  status CapitalApplicationStatus @default(SUBMITTED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("capital_applications")
}